# Force LF on YAML/JSON/Markdown so Linux CI runners always see consistent
# line endings even when the repo is checked out on Windows.
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.sh    text eol=lf

# Binary assets — never touch.
*.png   binary
*.jpg   binary
*.zip   binary
