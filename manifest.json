{
  "manifest_version": 3,
  "name": "Definition Popup",
  "version": "1.0.0",
  "description": "Highlight any word on a page to see its dictionary definition. Falls back to Urban Dictionary when no standard entry exists.",
  "author": "Nachtalb",
  "homepage_url": "https://github.com/Nachtalb/definition-popup",
  "host_permissions": [
    "https://freedictionaryapi.com/*",
    "https://www.urbandictionary.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Definition Popup",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
